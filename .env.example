# === Storage ===
# Postgres (Neon/Railway). Leave empty to use a local SQLite file.
# postgres:// and libpq params (sslmode/channel_binding) are normalized for asyncpg.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Your own Telegram numeric user id (the bot answers ONLY to this id).
# Get it from @userinfobot.
ALLOWED_TELEGRAM_USER_ID=123456789

# === Anthropic (Claude) — vision + extraction ===
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

# === Yandex SpeechKit — voice transcription ===
# Telegram .ogg/opus is sent as-is (no ffmpeg).
YANDEX_SPEECHKIT_API_KEY=AQVN...
# Recognition language. ru-RU by default; use "auto" to autodetect.
YANDEX_STT_LANG=ru-RU

# === Web dashboard ===
# Leave empty for no login. Set a password to gate the site (cookie session).
WEB_PASSWORD=
# Public URL of the deployed dashboard — used by the bot to link trades.
WEB_BASE_URL=

# === Account / locale ===
INITIAL_BALANCE=0
# Timezone for session math (zoneinfo). Do not change unless you know why.
TRADER_TIMEZONE=America/New_York
