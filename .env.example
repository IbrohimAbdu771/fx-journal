# === Telegram ===
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Your own Telegram numeric user id (the bot answers ONLY to this id).
# Get it from @userinfobot.
ALLOWED_TELEGRAM_USER_ID=123456789

# === Anthropic (Claude) — vision + extraction ===
ANTHROPIC_API_KEY=sk-ant-...

# === Yandex SpeechKit — voice transcription ===
# Reused from the Worka project. Telegram .ogg/opus is sent as-is (no ffmpeg).
YANDEX_SPEECHKIT_API_KEY=AQVN...
# Recognition language. ru-RU by default; use "auto" to autodetect.
YANDEX_STT_LANG=ru-RU

# === Notion ===
NOTION_TOKEN=ntn_...
# Filled in automatically after running `python setup_notion.py`.
NOTION_DATABASE_ID=
# Only needed for setup_notion.py: the page under which the DB + dashboard
# are created. Copy the 32-char id from the page URL and share the page with
# your Notion integration first.
NOTION_PARENT_PAGE_ID=

# === Optional ===
# Timezone for session math. Do not change unless you know why.
TRADER_TIMEZONE=America/New_York
